// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String    @map("password_hash")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  topics        Topic[]
  revisions     Revision[]
  practiceSessions PracticeSession[]

  @@map("users")
}

model Topic {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  title         String
  category      String
  notes         String
  codeSnippet   String?   @map("code_snippet")
  strengthScore Int       @default(0) @map("strength_score")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  revisions     Revision[]
  practiceSessions PracticeSession[]

  @@index([userId])
  @@map("topics")
}

model Revision {
  id            String    @id @default(uuid())
  topicId       String    @map("topic_id")
  dueDate       DateTime  @map("due_date")
  confidence    String?   // forgot, partial, strong
  nextDueDate   DateTime? @map("next_due_date")
  status        String    @default("pending") // pending, completed, missed
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  topic         Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id])
  userId        String

  @@index([topicId])
  @@index([dueDate])
  @@index([userId, dueDate])
  @@map("revisions")
}

model PracticeSession {
  id            String    @id @default(uuid())
  topicId       String    @map("topic_id")
  userId        String    @map("user_id")
  question      String
  answer        String
  result        String    // correct, partial, incorrect
  completedAt   DateTime  @default(now()) @map("completed_at")

  topic         Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id])

  @@index([topicId])
  @@index([userId])
  @@map("practice_sessions")
}
